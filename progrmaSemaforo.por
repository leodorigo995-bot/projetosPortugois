programa {
  funcao inicio() {
    //programa semaforo
    real velocidade// declarando variavel
    //entrada de dados
    escreva("Qual tua velcidade??")
    leia (velocidade)
    
    //Estrutura  }
    se (velocidade > 80){
      escreva ("PERDEU PLAYBOY!! Levou multa")
    }senao{
      escreva("Velocidade aceitael, passar bem!")
    }
    escreva("\n")// quebra uma linha
}
}
